# ── APEX Low-Float Screener — environment variables ─────────────────────────
# Copy this file to .env and fill in your keys.

# Anthropic (required for Phase 2 filing classifier)
ANTHROPIC_API_KEY=sk-ant-...

# Polygon.io (required for live price/volume/halt data)
POLYGON_API_KEY=...

# Finviz Elite (optional — free scraping works without this)
FINVIZ_API_KEY=

# ── Mock mode (set to "true" to bypass live API calls) ──────────────────────
# Leave these as "true" during development; flip to "false" when keys are set.
USE_MOCK_POLYGON=true
USE_MOCK_FINVIZ=true
